<p class="m-0 text-secondary">Показанао <span>@MetaData.PageSize</span>. Всего страниц <span>@MetaData.TotalPages</span></p>
<ul class="pagination m-0 ms-auto">
    @foreach(var link in _links)
    {
        <li @onclick="()=>OnSelectedPage(link)" class="page-item @(link.Enabled ? null : "disabled") @(link.Active ? "active" : null)">
            <span class="page-link">@link.Text</span>
        </li>
    }
</ul>